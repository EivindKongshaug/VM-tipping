<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VM 2026 Live Tipping</title>
<style>
body { font-family: Arial; background:#0b0f1a; color:white; margin:0; }
header { padding:20px; text-align:center; background:#111a2b; }
h1 { margin:0; }
.card { background:#151f33; margin:10px; padding:10px; border-radius:10px; }
.leader { border:2px solid gold; }
.row { display:flex; justify-content:space-between; }
.small { font-size:12px; color:#aaa; }
</style>
</head>
<body>
<header>
<h1>⚽ VM 2026 Tipping LIVE</h1>
<p class="small">Oppdateres automatisk hvert 60 sek</p>
</header>
<div id="table"></div>
<script>
const API_KEY = 234985fb7b4a22f79103b10751c61806;
const PLAYERS = ["Staals","Kong","Dox","Jojo","Marko","Barra"];
// DINE MATCHES (forkortet her – jeg kan legge inn alle 72 hvis du vil)
const MATCHES = [
 {id:1, home:"Mexico", away:"South Africa", tips:["3-0","2-1","2-0","3-1","2-1","3-0"]},
 {id:2, home:"South Korea", away:"Czech Republic", tips:["2-1","1-1","1-1","2-3","1-0","1-2"]},
 {id:3, home:"Canada", away:"Bosnia", tips:["1-1","0-1","2-1","2-0","1-1","2-0"]},
];
// resultater
let results = {};
async function fetchResults() {
  try {
    const res = await fetch("https://v3.football.api-sports.io/fixtures?season=2026&league=1", {
      headers: { "x-apisports-key": API_KEY }
    });
    const data = await res.json();
    data.response.forEach(match => {
      if (match.fixture.status.short !== "FT") return;
      const home = match.teams.home.name;
      const away = match.teams.away.name;
      const score = match.goals.home + "-" + match.goals.away;
      const m = MATCHES.find(x => x.home === home && x.away === away);
      if (m) results[m.id] = score;
    });
    render();
  } catch(e) {
    console.log(e);
  }
}
function pts(actual, tip) {
  if (!actual) return 0;
  if (actual === tip) return 4;
  const a = actual.split("-"), t = tip.split("-");
  const resA = a[0]-a[1];
  const resT = t[0]-t[1];
  return (resA>0&&resT>0)||(resA<0&&resT<0)||(resA==0&&resT==0) ? 2 : 0;
}
function render() {
  let scores = PLAYERS.map((p,i)=>{
    let total=0;
    MATCHES.forEach(m=>{
      if(results[m.id]) total += pts(results[m.id], m.tips[i]);
    });
    return {p,total};
  }).sort((a,b)=>b.total-a.total);
  document.getElementById("table").innerHTML =
    scores.map((s,i)=>
      `<div class="card ${i===0?'leader':''}">
        <div class="row">
          <b>${i+1}. ${s.p}</b>
          <b>${s.total} pts</b>
        </div>
      </div>`
    ).join("");
}
fetchResults();
setInterval(fetchResults, 60000);
</script>
</body>
</html>